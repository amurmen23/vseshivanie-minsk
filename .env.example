# SMTP-настройки для api/send-email.js
# Скопируйте в .env.local для локальной разработки
# В Vercel добавьте эти переменные через Settings → Environment Variables

# SMTP-сервер (обычно совпадает с доменом почты)
SMTP_HOST=mail.rudolf.by

# Порт: 465 для SSL, 587 для STARTTLS
SMTP_PORT=465

# true — SSL (порт 465), false — STARTTLS (порт 587)
SMTP_SECURE=true

# Полный логин почтового ящика
SMTP_USER=bs.scale@rudolf.by

# Пароль приложения (не основной пароль, если включена 2FA)
SMTP_PASS=your_app_password_here

# Адрес получателя заявок (по умолчанию bs.scale@rudolf.by)
MAIL_TO=bs.scale@rudolf.by
